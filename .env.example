# Required: Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required for data collection pipeline: Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required for RAG pipeline: Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional — RAG pipeline (Qdrant Cloud for persistent storage)
# Leave blank to use in-memory Qdrant (data re-ingested on every startup)
# Get free cluster at https://cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=
